# .dockerignore — exclude from `docker build` context tarball.
#
# Every `docker build` from repo root would otherwise tarball the entire
# tree (node_modules, .terraform/, .git, aidlc-docs/, etc.) — slow + memory-
# hungry. This file shrinks the context to just the source files needed
# for the build.

# --- Version control ---
.git/
.gitignore
.gitattributes
.github/                       # CI configs not needed inside images

# --- OS / editor junk ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/

# --- Claude Code state ---
.claude/

# --- AI-DLC documentation (huge, not runtime) ---
aidlc-docs/
aidlc-inputs/
.aidlc-rule-details/
.ai-dlc-bootstrap/

# --- Per-language build/install artifacts ---
node_modules/
**/node_modules/
.pnpm-store/
dist/
**/dist/
build/
**/build/
*.tgz

# Python
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
htmlcov/
*.egg-info/
.venv/
**/.venv/

# Go
**/bin/
**/.go-build/

# --- Terraform ---
**/.terraform/
**/.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfplan
plan.bin
**/plan.bin

# --- Helm dependency build artefacts (regenerated by `helm dependency build`) ---
**/helm/charts/
**/helm/Chart.lock

# --- Logs / coverage / scratch ---
*.log
logs/
coverage/
*.cov
*.out
/tmp/

# --- Our session-specific scratch ---
harness/local-test-rig/local-test-rig    # compiled binary
deploy/                                    # not needed inside any image
scripts/                                   # operator scripts; never copied into images

# --- Container build artefacts (recursive Docker calls) ---
.dockerignore
Dockerfile.*
**/Dockerfile.test

# --- Misc ---
*.bak
*.orig
*.tmp
