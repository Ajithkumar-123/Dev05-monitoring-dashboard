{
  "name": "@docuploader/data-access",
  "version": "0.1.0",
  "description": "Typed data-access library for docuploader DynamoDB tables (TypeScript)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./workspaces": "./dist/workspaces/index.js",
    "./batches": "./dist/batches/index.js",
    "./documents": "./dist/documents/index.js",
    "./auditevents": "./dist/auditevents/index.js",
    "./contenthashes": "./dist/contenthashes/index.js",
    "./pipelinefiles": "./dist/pipelinefiles/index.js",
